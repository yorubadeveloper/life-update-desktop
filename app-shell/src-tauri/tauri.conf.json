{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Life-Update",
  "mainBinaryName": "Life-Update",
  "version": "0.3.0",
  "identifier": "com.life-update.desktop",
  "build": {
    "beforeDevCommand": "./scripts/build-ai-helper.sh && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "./scripts/build-ai-helper.sh && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Life-Update",
        "width": 1080,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/ai-helper": "ai-helper"
    },
    "macOS": {
      "signingIdentity": "-"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1QkM5QkU4MDdFRkVFRkQKUldUOTd1OEg2SnU4RmYrbHU5TjFNbmtCSlhXdFQvUlVyeGhMd0wrbWVQVjZ5WkRrZUxnbDI5dnEK",
      "endpoints": [
        "https://github.com/yorubadeveloper/life-update-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}