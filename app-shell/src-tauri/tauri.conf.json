{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "life-update",
  "version": "0.1.0",
  "identifier": "com.life-update.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "life-update",
        "width": 480,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/life-update-agent": "life-update-agent",
      "resources/ollama-runtime": "ollama-runtime",
      "resources/tesseract-runtime": "tesseract-runtime"
    },
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
