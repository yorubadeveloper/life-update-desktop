# Copy to .env and fill in.

# From life-update.com -> Settings -> Devices -> "Generate token"
LIFE_UPDATE_TOKEN=

# The life-update.com instance to sync to (use http://localhost:3000 against a local dev server)
LIFE_UPDATE_API_URL=https://life-update.com

# Local Ollama server used for session clustering/summarization
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# Minutes of no keyboard/mouse input before the inference worker is allowed to run
IDLE_THRESHOLD_MINUTES=3

# CPU load ceiling (percent), worker also waits below this
CPU_LOAD_CEILING_PERCENT=30

# Screen watching (opt-in, off by default) - reads what's on screen so
# sessions describe the actual work, not just which app was open
SCREEN_WATCH_ENABLED=false
SCREEN_CAPTURE_INTERVAL_SECONDS=120
VISION_ENGINE=tesseract
